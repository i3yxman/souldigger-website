{
  "name": "souldigger-website",
  "version": "1.0.0",
  "private": true,
  "description": "SoulDigger 官网（Vantara）- Next.js 长期维护版",
  "engines": {
    "node": ">=20.10.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "clean": "rimraf .next .next-dev out",
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "dev:fresh": "npm run clean && npm run dev",
    "build": "rimraf .next out && NEXT_DIST_DIR=.next next build",
    "start": "next start",
    "lint": "next lint",
    "export": "npm run build"
  },
  "dependencies": {
    "next": "15.5.12",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-next": "15.5.12",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  }
}
